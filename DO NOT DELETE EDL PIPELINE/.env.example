# Copy to .env only if your shell tooling loads env files automatically.
# The scripts also work when these variables are exported directly.

# Include stock and index OHLCV refresh. First run can be slow.
EDL_FETCH_OHLCV=1

# Include optional standalone outputs such as ETF scan.
EDL_FETCH_OPTIONAL=0

# Delete intermediate JSON/CSV/folder outputs after final gzip artifacts are written.
EDL_CLEANUP_INTERMEDIATE=1

# Optional: force the pipeline working directory when using an installed console command.
# EDL_BASE_DIR=/absolute/path/to/DO NOT DELETE EDL PIPELINE
